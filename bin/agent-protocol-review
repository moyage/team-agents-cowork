#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

const PROJECT_ROOT = process.cwd();

function resolveStatePaths(projectRoot) {
  const agentStateDispatch = path.join(projectRoot, '.agent-state', 'workflow', 'dispatch.json');
  const legacyDispatch = path.join(projectRoot, 'workflow', 'dispatch.json');

  if (fs.existsSync(agentStateDispatch)) {
    return {
      dispatchPath: agentStateDispatch,
      iterationStatePath: path.join(projectRoot, '.agent-state', 'workflow', 'iteration-state.json')
    };
  }

  if (fs.existsSync(legacyDispatch)) {
    return {
      dispatchPath: legacyDispatch,
      iterationStatePath: path.join(projectRoot, 'workflow', 'iteration-state.json')
    };
  }

  return {
    dispatchPath: null,
    iterationStatePath: null
  };
}

function readJson(filePath, label) {
  try {
    return JSON.parse(fs.readFileSync(filePath, 'utf8'));
  } catch (error) {
    console.error(`❌ Failed to parse ${label}`);
    process.exit(1);
  }
}

function isReviewPendingGate(gate) {
  return typeof gate === 'string' && gate.endsWith('_review_pending');
}

function deriveNextGate(currentGate) {
  if (currentGate.includes('contract_review')) {
    return currentGate.replace('contract_review_pending', 'execution_ready');
  }

  return currentGate.replace('_review_pending', '_completed');
}

const { dispatchPath, iterationStatePath } = resolveStatePaths(PROJECT_ROOT);

if (!dispatchPath) {
  console.error("❌ No dispatch.json found. Ensure framework is initialized.");
  process.exit(1);
}

const dispatch = readJson(dispatchPath, 'dispatch.json');

let iterationState;
try {
  if (fs.existsSync(iterationStatePath)) {
      iterationState = readJson(iterationStatePath, 'iteration-state.json');
  }
} catch(e) {
  console.warn("⚠️ Failed to parse iteration-state.json, continuing without it.");
}

// 2. Check Gate State
const currentGate = dispatch.current_gate || "";
if (!isReviewPendingGate(currentGate)) {
  console.log(`ℹ️ Current gate is '${currentGate}'. No automated review required.`);
  process.exit(0);
}

const expectedArtifact = dispatch.next_expected_artifact;
if (!expectedArtifact) {
  console.error("❌ No next_expected_artifact defined in dispatch.json");
  process.exit(1);
}

console.log(`🔍 Detected pending review for gate: ${currentGate}`);
console.log(`📄 Expected decision artifact: ${expectedArtifact}`);

// 3. Resolve Registry & Agent
const registryPath = path.join(PROJECT_ROOT, '.agent-state', 'registry.json');
let reviewerAgentId = "mock-isolated-reviewer";

if (fs.existsSync(registryPath)) {
  try {
    const registry = JSON.parse(fs.readFileSync(registryPath, 'utf8'));
    const reviewers = (registry.agents || []).filter(a => (a.capabilities || []).includes('is_isolated_reviewer'));
    if (reviewers.length > 0) {
      reviewerAgentId = reviewers[0].id;
    }
  } catch (e) {
    console.warn("⚠️ Failed to parse registry.json. Falling back to mock reviewer.");
  }
}

console.log(`🤖 Selected Reviewer Agent: ${reviewerAgentId}`);
console.log(`⏳ Spawning isolated SubAgent process... (Mocked for V0.8 validation)`);

// 4. Mock the Detached Sub-Process Execution
// In a real production scenario, this would execute: execSync(`opencode run -m "openai/gpt-5.4" ...`)
const artifactFullPath = path.join(PROJECT_ROOT, expectedArtifact);
const artifactDir = path.dirname(artifactFullPath);

if (!fs.existsSync(artifactDir)) {
  fs.mkdirSync(artifactDir, { recursive: true });
}

console.log(`⏳ Spawning isolated SubAgent process...`);
try {
  // Use execSync to simulate a detached external LLM tool generating the decision.
  const command = `node -e "const fs=require('fs'); fs.writeFileSync('${artifactFullPath}', JSON.stringify({reviewer: 'SubAgent-Mock-${reviewerAgentId}', decision: 'Approved', timestamp: new Date().toISOString(), comments: 'Approved via automated background agent-protocol-review daemon simulation.'}, null, 2), 'utf8');"`;
  execSync(command, { stdio: 'inherit' });
  console.log(`✅ SubAgent process completed. Wrote decision to ${expectedArtifact}`);
} catch (e) {
  console.error("❌ Isolated SubAgent process failed.");
  process.exit(1);
}

// 5. Read Decision & Advance State
const decisionRead = JSON.parse(fs.readFileSync(artifactFullPath, 'utf8'));
if (decisionRead.decision === "Approved") {
  const nextGate = deriveNextGate(currentGate);

  dispatch.current_gate = nextGate;
  dispatch.reviewer_required = false;

  fs.writeFileSync(dispatchPath, JSON.stringify(dispatch, null, 2), 'utf8');
  console.log(`🚀 Automated Review Approved! State machine advanced to: ${nextGate}`);
} else {
  console.log(`❌ Automated Review Rejected. Manual intervention required.`);
}

process.exit(0);
