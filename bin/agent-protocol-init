#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

const PROJECT_ROOT = process.cwd();

function createDirectoryIfNotExists(dirPath) {
  if (!fs.existsSync(dirPath)) {
    fs.mkdirSync(dirPath, { recursive: true });
    console.log(`\x1b[32mCreated directory: ${dirPath}\x1b[0m`);
  }
}

function writeFileIfNotExists(filePath, content) {
  if (!fs.existsSync(filePath)) {
    fs.writeFileSync(filePath, content.trim() + '\n', 'utf8');
    console.log(`\x1b[32mCreated file: ${filePath}\x1b[0m`);
  } else {
    console.log(`\x1b[33mSkipped (already exists): ${filePath}\x1b[0m`);
  }
}

console.log(`\x1b[36mInitializing Team Agents Cowork protocol at: ${PROJECT_ROOT}\x1b[0m`);

// 1. Scaffold the .agent-state directory
const agentStateDir = path.join(PROJECT_ROOT, '.agent-state');
createDirectoryIfNotExists(agentStateDir);
createDirectoryIfNotExists(path.join(agentStateDir, 'workflow'));
createDirectoryIfNotExists(path.join(agentStateDir, 'tasks'));
createDirectoryIfNotExists(path.join(agentStateDir, 'workflows'));

// 2. Generate default workflow/dispatch.json inside .agent-state
const defaultDispatch = {
  "active_iteration": "V0.0",
  "current_gate": "kickoff_pending",
  "executor": null,
  "reviewer_required": false,
  "active_task": null,
  "stop_conditions": [],
  "next_expected_artifact": "tasks/v0.0-kickoff-packet.md"
};
writeFileIfNotExists(path.join(agentStateDir, 'workflow', 'dispatch.json'), JSON.stringify(defaultDispatch, null, 2));

// 3. Generate .agent-state/registry.json (V0.8 M2 Requirement)
const defaultRegistry = {
  agents: [
    {
      id: "hermes-local",
      type: "orchestrator",
      capabilities: ["mcp_client", "terminal_access", "file_system"],
      description: "Local main brain executor"
    },
    {
      id: "opencode-sisyphus",
      type: "executor",
      capabilities: ["terminal_access", "background_process", "is_isolated_reviewer"],
      description: "CLI agent for execution and isolated gatekeeping"
    }
  ]
};
writeFileIfNotExists(path.join(agentStateDir, 'registry.json'), JSON.stringify(defaultRegistry, null, 2));

// 4. Instruct user to update .gitignore
console.log(`\x1b[33mRemember to add .agent-state/ to your .gitignore if you do not want state persisted to remote origin.\x1b[0m`);
console.log(`\x1b[32mProtocol initialization complete. Environment registry scaffolded.\x1b[0m`);
